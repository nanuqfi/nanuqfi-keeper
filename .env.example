# RPC endpoints (ordered by priority)
RPC_URL_PRIMARY=https://your-helius-rpc.com
RPC_URL_FALLBACK=https://your-triton-rpc.com

# Keeper wallet
KEEPER_KEYPAIR_PATH=/path/to/keeper-keypair.json

# Cycle intervals
CYCLE_INTERVAL_MS=600000
AI_CYCLE_INTERVAL_MS=7200000

# AI provider
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_CALLS_PER_HOUR=10
AI_BUDGET_PER_DAY=5

# Alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
