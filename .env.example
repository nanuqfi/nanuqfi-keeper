# ─── RPC Endpoints ────────────────────────────────────────────────────────────
# Ordered by priority. Primary is tried first; fallback used on failure.
# Recommended: Helius (devnet/mainnet) for reliability and rate limits.
RPC_URL_PRIMARY=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
RPC_URL_FALLBACK=https://api.devnet.solana.com

# ─── Keeper Wallet ────────────────────────────────────────────────────────────
# Path to the keeper authority keypair JSON file (Solana CLI format).
# Must match the keeper_authority set in the on-chain allocator.
KEEPER_KEYPAIR_PATH=/path/to/keeper-keypair.json

# ─── Cycle Intervals ──────────────────────────────────────────────────────────
# How often the algorithm engine runs (milliseconds). Minimum: 10000 (10s).
CYCLE_INTERVAL_MS=600000
# How often the AI reasoning cycle runs (milliseconds).
AI_CYCLE_INTERVAL_MS=7200000

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Anthropic API key for Claude. Set OPENROUTER_API_KEY as alternative.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: custom base URL (e.g. OpenRouter endpoint)
# AI_BASE_URL=https://openrouter.ai/api/v1
# Model identifier — defaults to claude-sonnet-4-6
AI_MODEL=claude-sonnet-4-6
# Rate limits for the AI layer
AI_MAX_CALLS_PER_HOUR=10
AI_BUDGET_PER_DAY=5

# ─── Protocol API Keys ────────────────────────────────────────────────────────
# Lulo API key — required for live Lulo yield rates.
# Without this, the keeper falls back to a hardcoded rate (7%) and alerts.
# Obtain from: https://lulo.fi or contact the Lulo team.
LULO_API_KEY=

# ─── On-Chain Config ──────────────────────────────────────────────────────────
# USDC mint address — defaults to NanuqFi devnet test mint if unset.
# Override for mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Alerting ─────────────────────────────────────────────────────────────────
# Telegram bot token and chat ID for operational alerts.
# Leave empty to disable Telegram alerts (alerts are logged to console instead).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── API Server ───────────────────────────────────────────────────────────────
# HTTP port for the keeper API (health, vaults, decisions, backtest).
PORT=3000
# Comma-separated list of allowed CORS origins for the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://nanuqfi.com

# ─── Persistence Paths ────────────────────────────────────────────────────────
# Paths for persisted state (Docker volume mount recommended).
AI_HISTORY_PATH=/data/ai-history.json
DECISION_HISTORY_PATH=/data/decision-history.json
HEALTH_STATS_PATH=/data/health-stats.json
